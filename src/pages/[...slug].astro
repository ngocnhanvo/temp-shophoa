export const data_products = await getProducts(data_info[0], pages);
data_products.map(product => {
  Object.keys(product.slug).map((p: string) => {
    pages.push({
      key: `product`,
      id: product._id,
      lang: p,
      slug: product.slug[p],
      slugP: product.slugP[p],
      label: `${product.itemName[p] || 'Sản phẩm'}`,
      title: `${companyName[p] || 'Vibe Code Studio'} - The Fusion of AI and Experts`,
      action: 'ProductDetailPage',
      description: `${product.itemDescription[p] || 'Sản phẩm'}`,
      ogImage: product.itemImage[p].src,
      header: false
    });
  });
});

export async function getStaticPaths() {  
  // Gọi hàm tạo sitemap sau khi tất cả các trang đã được thu thập
  await generateAndSaveSitemap(pages, data_info);
  // 2. Map mảng pages sang định dạng của Astro
  return pages.map(page => {
    const dictionary = {
      tencongty: data_info.tencongty[page.lang],
      diachi: data_info.diachi[page.lang]
    };
    const title = replacePlaceholders(page.title, dictionary);
    const description = replacePlaceholders(page.description, dictionary); 

    return {
      params: { slug: page.slug == "" ? undefined : page.slug },
      props: {
        type: 'home',
        baseUrl: WC_URL,
        title: title,
        description: description,
        ogImage: page.ogImage,
      }
    };
  });
}

const lang = returnLang(pages, Astro.url.pathname);
const props: AppRouterProps = {
  basename: '/',
  pages: pages,
  data_info: data_info,
  data_pages: data_pages,
  data_products: data_products
};
// Sử dụng Astro.url để lấy URL chính xác, đảm bảo không bị lỗi double slash
const siteOrigin = (WC_URL_CLIENT || Astro.url.origin).replace(/\/$/, '');
const currentPageUrl = new URL(Astro.url.pathname, siteOrigin).href;
const headProps: HeadProps = {
  title: Astro.props.title,
  href: currentPageUrl,
  ogImage: siteOrigin + Astro.props.ogImage,
  description: Astro.props.description,
  lang: lang,
  data_info: data_info
}
---
<html lang={lang} class="w-full h-full">
  <head>
    <Head {...headProps} />
  </head>
  <body class="w-full h-full">
    <PageTransition client:load />
    <div style="display:none">Build ID: {Date.now()}</div>
    <div id="root" class="w-full h-full">
      <AppRouter client:idle {...props} />
    </div>
  </body>
</html>
